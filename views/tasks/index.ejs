<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
        rel="stylesheet"
        integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr"
        crossorigin="anonymous"
    >

    <title><%= pageTitle %></title>
</head>

<body class="bg-light">
    <main class="container py-5">
        <div class="row g-5">
            <div class="col-lg-5">
                <div class="card shadow-sm">
                    <div class="card-body p-4">


                    <!-- Main Task creation from -->
                        <h1 class="h3 mb-4">Create Task</h1>

                        <form action="/tasks" method="POST">

                            <div class="mb-3">
                                <label for="title" class="form-label">
                                    Title
                                </label>

                                <input
                                    type="text"
                                    class="form-control"
                                    id="title"
                                    name="title"
                                    placeholder="Enter task title"
                                    required
                                >
                            </div>

                            <div class="mb-3">
                                <label for="description" class="form-label">
                                    Description
                                </label>

                                <textarea
                                    class="form-control"
                                    id="description"
                                    name="description"
                                    rows="3"
                                    placeholder="Optional description"
                                ></textarea>
                            </div>

                            <div class="mb-3">
                                <label for="status" class="form-label">
                                    Status
                                </label>

                                <select
                                    class="form-select"
                                    id="status"
                                    name="status"
                                >
                                    <option value="PENDING">Pending</option>
                                    <option value="DONE">Done</option>
                                </select>
                            </div>

                            <div class="mb-4">
                                <label for="dueDate" class="form-label">
                                    Due Date
                                </label>

                                <input
                                    type="date"
                                    class="form-control"
                                    id="dueDate"
                                    name="dueDate"
                                >
                            </div>

                            <button
                                type="submit"
                                class="btn btn-primary w-100"
                            >
                                Save Task
                            </button>

                        </form>

                    </div>
                </div>
            </div>

           
            <div class="col-lg-7">
                <h2>Current Tasks</h2>
                <form action="/" method="GET" class="mb-4">

                    <!-- Search bar to search for specific task-->
                    <div class="input-group">
                        <input
                            type="search"
                            class="form-control"
                            name="search"
                            placeholder="Search tasks by title"
                            value="<%= search %>"
                        >

                        <button type="submit" class="btn btn-dark">
                            Search
                        </button>

                        <a href="/" class="btn btn-outline-secondary">
                            Clear
                        </a>
                    </div>
                </form>
                
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="h3 mb-1">Current Tasks</h2>
                        <p class="text-muted mb-0">
                            View and manage your tasks.
                        </p>
                    </div>
                </div>

                <!-- Form validation and database manipulation -->

                <% if (tasks.length === 0) { %>

                    <div class="alert alert-secondary">
                        You have no tasks yet. Add your first task to get started!
                    </div>

                <% } else { %>

                    <% for (const task of tasks) { %>

                        <div class="card shadow-sm mb-3">
                            <div class="card-body">

                                <div class="d-flex justify-content-between align-items-start gap-3">

                                    <div>
                                        <h3 class="h5 card-title mb-2">
                                            <%= task.title %>
                                        </h3>

                                        <% if (task.description) { %>

                                            <p class="card-text text-muted mb-3">
                                                <%= task.description %>
                                            </p>

                                        <% } else { %>

                                            <p class="card-text text-muted mb-3">
                                                No description provided.
                                            </p>

                                        <% } %>

                                        <p class="mb-1">
                                            <strong>Status:</strong>
                                            <span
                                                class="badge <%= task.status === 'DONE'
                                                    ? 'text-bg-success'
                                                    : 'text-bg-warning' %>"
                                            >
                                                <%= task.status %>
                                            </span>
                                        </p>

                                        <p class="mb-0 text-muted">
                                            <strong>Due date:</strong>
                                            <%= task.dueDate
                                                ? task.dueDate.toLocaleDateString("en-ZA")
                                                : "No due date" %>
                                        </p>
                                    </div>
                                </div>

                                <!-- Status toggle feature, change from pending to done or other way around-->
                                <div class="d-flex flex-wrap gap-2 mt-4">

                                    <form
                                        action="/tasks/<%= task.id %>/toggle"
                                        method="POST"
                                    >
                                        <button
                                            type="submit"
                                            class="btn btn-outline-success"
                                        >
                                            <%= task.status === "PENDING"
                                                ? "Mark done"
                                                : "Mark pending" %>
                                        </button>
                                    </form>

                                    <!-- Delete button to delete any task-->
                                    <form
                                        action="/tasks/<%= task.id %>/delete"
                                        method="POST"
                                        onsubmit="return confirm('Are you sure you want to delete this task?')"
                                    >
                                        <button
                                            type="submit"
                                            class="btn btn-outline-danger"
                                        >
                                            Delete
                                        </button>
                                    </form>

                                    <!-- Edit button to change any value from a perticular task -->

                                    <button
                                        class="btn btn-primary"
                                        type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#editTask<%= task.id %>"
                                        >
                                     Edit
                                    </button>

                                    <!-- Update button to save the changes from a edited form-->

                                    <div class="collapse mt-3" id="editTask<%= task.id %>">
                                        <form action="/tasks/<%= task.id %>/update" method="POST">

                                            <div class="mb-3">
                                                <label class="form-label" for="title<%= task.id %>">
                                                    Title
                                                </label>

                                                <input
                                                    class="form-control"
                                                    id="title<%= task.id %>"
                                                    name="title"
                                                    type="text"
                                                    value="<%= task.title %>"
                                                    required
                                                >
                                            </div>

                                            <div class="mb-3">
                                                <label class="form-label" for="description<%= task.id %>">
                                                    Description
                                                </label>

                                                <textarea
                                                    class="form-control"
                                                    id="description<%= task.id %>"
                                                    name="description"
                                                ><%= task.description || "" %></textarea>
                                            </div>

                                            <div class="mb-3">
                                                <label class="form-label" for="status<%= task.id %>">
                                                    Status
                                                </label>

                                                <select
                                                    class="form-select"
                                                    id="status<%= task.id %>"
                                                    name="status"
                                                >
                                                    <option
                                                        value="PENDING"
                                                        <%= task.status === "PENDING" ? "selected" : "" %>
                                                    >
                                                        Pending
                                                    </option>

                                                    <option
                                                        value="DONE"
                                                        <%= task.status === "DONE" ? "selected" : "" %>
                                                    >
                                                        Done
                                                    </option>
                                                </select>
                                            </div>

                                            <div class="mb-3">
                                                <label class="form-label" for="dueDate<%= task.id %>">
                                                    Due Date
                                                </label>

                                                <input
                                                    class="form-control"
                                                    id="dueDate<%= task.id %>"
                                                    name="dueDate"
                                                    type="date"
                                                    value="<%= task.dueDate
                                                        ? task.dueDate.toISOString().slice(0, 10)
                                                        : "" %>"
                                                >
                                            </div>

                                            <button class="btn btn-primary" type="submit">
                                                Save Changes
                                            </button>
                                        </form>
                                    </div>
                                </div>

                            </div>
                        </div>

                    <% } %>

                <% } %>

            </div>

        </div>

    </main>

    <script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-ndDqU0Gzau9qJ1lfW4pNLlhNTkCfHzAVBReH9diLvGRem5+R9g2FzA8ZGN954O5Q"
        crossorigin="anonymous"
    ></script>

</body>

</html>